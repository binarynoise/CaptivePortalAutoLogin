<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/CaptivePortalAutoLogin.Edge2EdgeFix"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".preferences.onboarding.LocationFragment"
    >
    
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/setup_padding_horizontal"
            >
            
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_dialog_map"
                />
            
            
            <TextView
                style="@style/CaptivePortalAutoLogin.Setup.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/setup_padding_vertical"
                android:text="@string/setup_location"
                />
            
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/permissionsFragmentContainerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                />
        
        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
